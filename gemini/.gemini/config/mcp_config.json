{
  "mcpServers": {
    "figma-dev-mode-mcp-server": {
      "serverUrl": "http://127.0.0.1:3845/mcp"
    },
    "figma-remote-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "node",
      "args": [
        "-e",
        "require(require('os').homedir()+'/dotfiles/mcp-runner.js')",
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "node",
      "args": [
        "-e",
        "require(require('os').homedir()+'/dotfiles/mcp-runner.js')",
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "dart-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "dart",
      "args": [
        "mcp-server"
      ],
      "env": {}
    },
    "firebase-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "mcp"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "chrome-devtools-mcp": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    },
    "github-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "node",
      "args": [
        "-e",
        "require(require('os').homedir()+'/dotfiles/mcp-runner.js')",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "mcp-server-neon": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.neon.tech/sse"
      ],
      "env": {}
    },
    "supabase": {
      "serverUrl": "https://mcp.supabase.com/mcp"
    },
    "prisma-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "prisma",
        "mcp"
      ],
      "env": {}
    },
    "graphify": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "graphifyy",
        "--with",
        "mcp",
        "-m",
        "graphify.serve",
        "${workspace.path}/graphify-out/graph.json"
      ]
    }
  }
}