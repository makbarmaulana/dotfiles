{
  "mcpServers": {
    "figma-dev-mode-mcp-server": {
      "serverUrl": "http://127.0.0.1:3845/mcp"
    },
    "figma-remote-mcp-server": {
      "type": "http",
      "serverUrl": "https://mcp.figma.com/mcp"
    },
    "github-mcp-server": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token) npx -y @modelcontextprotocol/server-github"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "source $HOME/dotfiles/.secrets.env 2>/dev/null; env CONTEXT7_API_KEY=\"$CONTEXT7_API_KEY\" npx -y @upstash/context7-mcp@latest"
      ]
    },
    "dart-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "dart",
      "args": [
        "mcp-server"
      ],
      "env": {}
    },
    "firebase-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "mcp"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "chrome-devtools-mcp": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    }
  }
}